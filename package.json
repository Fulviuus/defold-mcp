{
  "name": "defold-mcp-server",
  "version": "1.0.1",
  "description": "MCP server for the Defold game engine: project inspection, game.project editing, bob builds and bundles, running games, hot reload, live engine control and API documentation search",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "defold-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle:server": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node18 --outfile=desktop/src-tauri/resources/server.cjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test \"test/*.test.mjs\""
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "defold",
    "game-engine",
    "bob",
    "hot-reload"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fflate": "^0.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
